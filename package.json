{
  "name": "openharness-workspace",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goondan/openharness.git"
  },
  "homepage": "https://github.com/goondan/openharness#readme",
  "bugs": {
    "url": "https://github.com/goondan/openharness/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "verify": "pnpm build && pnpm typecheck && pnpm test",
    "publish:check": "node ./scripts/check-publish-ready.mjs",
    "publish:packages": "node ./scripts/publish-public-packages.mjs",
    "publish:packages:local": "node ./scripts/publish-public-packages.mjs --no-provenance"
  },
  "devDependencies": {
    "@types/node": "^22.19.7",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
