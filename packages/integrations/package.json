{
  "name": "@goondan/openharness-integrations",
  "version": "0.0.1-alpha3",
  "description": "Optional integration tools (e.g. Slack, Telegram) for OpenHarness",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "homepage": "https://github.com/goondan/openharness#readme",
  "bugs": {
    "url": "https://github.com/goondan/openharness/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goondan/openharness.git",
    "directory": "packages/integrations"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "agent",
    "harness",
    "integrations",
    "slack",
    "telegram"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.json && node ./build-manifest.mjs",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@goondan/openharness-types": "^0.0.1-alpha3"
  }
}
