{
  "name": "@goondan/openharness",
  "version": "0.0.1-alpha2",
  "description": "Barebone harness engine for turn, step, and tool-call agent runtimes",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/goondan/openharness#readme",
  "bugs": {
    "url": "https://github.com/goondan/openharness/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goondan/openharness.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "agent",
    "framework",
    "harness",
    "llm",
    "yaml"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.json",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.44",
    "@ai-sdk/google": "^3.0.29",
    "@ai-sdk/openai": "^3.0.29",
    "@goondan/openharness-types": "^0.0.1-alpha2",
    "ai": "^6.0.86",
    "yaml": "^2.8.1",
    "unique-names-generator": "^4.7.1"
  }
}
