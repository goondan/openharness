{
  "name": "@goondan/openharness-cli",
  "version": "0.1.13",
  "type": "module",
  "bin": {
    "oh": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "prepack": "pnpm build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@goondan/openharness": "workspace:*",
    "@goondan/openharness-types": "workspace:*",
    "dotenv": "^16.4.0",
    "jiti": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
